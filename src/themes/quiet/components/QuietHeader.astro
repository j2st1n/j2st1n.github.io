---
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconTrendingUp from "@/assets/icons/IconTrendingUp.svg";
import SiteLogo from "@/assets/icons/SiteLogo.svg";
import { SITE } from "@/config";
---

<header class="site-header" aria-label="站点导航">
  <div class="site-header-inner">
    <a href="/" class="site-brand" aria-label={`${SITE.title} 首页`}>
      <SiteLogo class="brand-logo" aria-hidden="true" />
      <span>{SITE.title}</span>
    </a>
    <nav class="site-tools" aria-label="站点工具">
      <a
        href="https://hot.bins.blog/"
        class="tool-link"
        title="热点追踪"
        aria-label="热点追踪"
      >
        <IconTrendingUp />
      </a>
      <a href="/search" class="tool-link" title="搜索" aria-label="搜索">
        <IconSearch />
      </a>
      <button
        id="theme-btn"
        class="theme-button"
        title="切换明暗主题"
        aria-label="切换明暗主题"
        aria-pressed="false"
      >
        <IconMoon class="theme-icon moon-icon" />
        <IconSunHigh class="theme-icon sun-icon" />
      </button>
    </nav>
  </div>
</header>
