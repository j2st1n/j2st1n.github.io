---
const endpoint = "https://hot.bins.blog/api/v1/overview";
---

<section
  class="live-signals"
  aria-labelledby="live-signals-title"
  data-live-signals
  data-endpoint={endpoint}
>
  <div class="live-signals-head">
    <div>
      <div id="live-signals-title" class="live-signals-label">实时热点</div>
      <p>从多个公开榜单识别正在升温的事件</p>
    </div>
    <a href="https://hot.bins.blog/" class="live-signals-action">
      查看全部 <span aria-hidden="true">→</span>
    </a>
  </div>
  <ol class="live-signals-list" data-signal-list aria-live="polite">
    <li class="live-signals-loading">正在读取热点信号…</li>
  </ol>
  <noscript>
    <p class="live-signals-noscript">
      <a href="https://hot.bins.blog/">前往热点追踪</a>
    </p>
  </noscript>
</section>

<style>
  .live-signals {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .live-signals-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .live-signals-label {
    color: var(--foreground);
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
  }

  .live-signals-head p {
    margin-top: 0.2rem;
    color: var(--foreground);
    opacity: 0.42;
    font-size: 0.75rem;
    line-height: 1.5;
  }

  .live-signals-action {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--foreground);
    opacity: 0.52;
    text-decoration: none;
    font-size: 0.8125rem;
    transition:
      opacity 0.2s ease,
      color 0.2s ease,
      gap 0.2s ease;
  }

  .live-signals-action:hover {
    opacity: 1;
    color: var(--accent);
    gap: 0.55rem;
  }

  .live-signals-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .live-signals-loading,
  .live-signals-noscript {
    margin: 0;
    padding: 1.25rem 0;
    color: var(--foreground);
    opacity: 0.42;
    font-size: 0.8125rem;
  }

  .live-signals-noscript a {
    color: inherit;
  }

  :global(.live-signal-item) {
    border-bottom: 1px solid var(--border-color);
  }

  :global(.live-signal-item:last-child) {
    border-bottom: 0;
  }

  :global(.live-signal-link) {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr) auto;
    gap: 1.25rem;
    align-items: start;
    padding: 1rem 0;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  :global(.live-signal-link:hover) {
    transform: translateX(2px);
  }

  :global(.live-signal-link:hover .live-signal-title) {
    color: var(--accent);
  }

  :global(.live-signal-index) {
    padding-top: 0.25rem;
    color: var(--foreground);
    opacity: 0.24;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  :global(.live-signal-body) {
    min-width: 0;
  }

  :global(.live-signal-title) {
    display: block;
    overflow: hidden;
    color: var(--foreground);
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.5;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  :global(.live-signal-meta) {
    display: block;
    margin-top: 0.25rem;
    color: var(--foreground);
    opacity: 0.45;
    font-size: 0.75rem;
    line-height: 1.5;
  }

  :global(.live-signal-score) {
    padding-top: 0.2rem;
    color: var(--foreground);
    opacity: 0.68;
    font-size: 0.8125rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 640px) {
    .live-signals {
      padding: 2rem 0;
    }

    .live-signals-head p {
      max-width: 15rem;
    }

    :global(.live-signal-link) {
      grid-template-columns: 2.75rem minmax(0, 1fr) auto;
      gap: 0.875rem;
    }
  }
</style>

<script is:inline>
  (() => {
    const signalCategories = {
      technology: "科技与 AI",
      "open-source": "开源与开发者",
      finance: "财经与市场",
      world: "国际事件",
      society: "社会热点",
    };

    const signalStatuses = {
      hot: "高热",
      rising: "升温中",
      cooling: "降温",
      watching: "观察",
    };

    const renderSignal = (event, index) => {
      const item = document.createElement("li");
      item.className = "live-signal-item";

      const link = document.createElement("a");
      link.className = "live-signal-link";
      link.href = `https://hot.bins.blog/?event=${event.id}`;

      const marker = document.createElement("span");
      marker.className = "live-signal-index";
      marker.textContent = String(index + 1).padStart(2, "0");

      const body = document.createElement("span");
      body.className = "live-signal-body";
      const title = document.createElement("span");
      title.className = "live-signal-title";
      title.textContent = event.canonical_title;
      const meta = document.createElement("span");
      meta.className = "live-signal-meta";
      meta.textContent = `${signalCategories[event.category] ?? event.category} · ${signalStatuses[event.status] ?? event.status}`;
      body.append(title, meta);

      const score = document.createElement("span");
      score.className = "live-signal-score";
      score.textContent = Math.round(event.current_score);

      link.append(marker, body, score);
      item.append(link);
      return item;
    };

    const initLiveSignals = async () => {
      const sections = document.querySelectorAll("[data-live-signals]");
      for (const section of sections) {
        if (section.dataset.state === "loading") continue;
        section.dataset.state = "loading";
        const list = section.querySelector("[data-signal-list]");

        try {
          const response = await fetch(section.dataset.endpoint, {
            headers: { Accept: "application/json" },
          });
          if (!response.ok) throw new Error(`HTTP ${response.status}`);
          const data = await response.json();
          const seen = new Set();
          const events = [...(data.rising ?? []), ...(data.confirmed ?? [])]
            .filter(event => {
              if (seen.has(event.id)) return false;
              seen.add(event.id);
              return true;
            })
            .slice(0, 3);
          if (!events.length) throw new Error("empty response");
          list.replaceChildren(...events.map(renderSignal));
          section.dataset.state = "ready";
        } catch {
          const fallback = document.createElement("li");
          fallback.className = "live-signals-loading";
          const link = document.createElement("a");
          link.href = "https://hot.bins.blog/";
          link.textContent = "热点服务暂不可用，打开完整页面";
          fallback.append(link);
          list.replaceChildren(fallback);
          section.dataset.state = "error";
        }
      }
    };

    document.addEventListener("astro:page-load", initLiveSignals);
    initLiveSignals();
  })();
</script>
