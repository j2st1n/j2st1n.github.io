---
import Layout from "@/layouts/Layout.astro";
import QuietHeader from "../components/QuietHeader.astro";
import QuietFooter from "../components/QuietFooter.astro";
import "../styles/quiet.css";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string | URL;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  showHeader?: boolean;
  footerMode?: "flow" | "balanced" | "none";
  isPost?: boolean;
  noindex?: boolean;
  nofollow?: boolean;
};

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  showHeader = true,
  footerMode = "flow",
  isPost = false,
  noindex = false,
  nofollow,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  scrollSmooth={scrollSmooth}
  isPost={isPost}
  noindex={noindex}
  nofollow={nofollow}
>
  <div class="quiet-shell" data-footer-mode={footerMode}>
    {showHeader && <a id="skip-to-content" href="#main-content" class="skip-link">跳到正文</a>}
    {showHeader && <QuietHeader />}
    <div class="quiet-content">
      <slot />
    </div>
    {footerMode !== "none" && <QuietFooter />}
  </div>
  <script is:inline>
    const themeButton = document.querySelector("#theme-btn");
    const html = document.documentElement;

    function syncThemeLabel() {
      themeButton?.setAttribute(
        "aria-label",
        html.dataset.theme === "dark" ? "切换到浅色主题" : "切换到深色主题"
      );
    }

    syncThemeLabel();
    themeButton?.addEventListener("click", () => {
      const nextTheme = html.dataset.theme === "dark" ? "light" : "dark";
      html.dataset.theme = nextTheme;
      localStorage.setItem("theme", nextTheme);
      syncThemeLabel();
    });
  </script>
</Layout>
