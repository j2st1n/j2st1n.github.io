---
import Layout from "@/layouts/Layout.astro";
import QuietHeader from "../components/QuietHeader.astro";
import QuietFooter from "../components/QuietFooter.astro";
import "../styles/quiet.css";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string | URL;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
  showHeader?: boolean;
  footerMode?: "flow" | "balanced" | "none";
  isPost?: boolean;
  noindex?: boolean;
  nofollow?: boolean;
  tags?: string[];
};

const {
  title,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
  showHeader = true,
  footerMode = "flow",
  isPost = false,
  noindex = false,
  nofollow,
  tags,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  ogImage={ogImage}
  canonicalURL={canonicalURL}
  pubDatetime={pubDatetime}
  modDatetime={modDatetime}
  scrollSmooth={scrollSmooth}
  isPost={isPost}
  noindex={noindex}
  nofollow={nofollow}
  tags={tags}
>
  <div class="quiet-shell" data-footer-mode={footerMode}>
    {showHeader && <a id="skip-to-content" href="#main-content" class="skip-link">跳到正文</a>}
    {showHeader && <QuietHeader />}
    <div class="quiet-content">
      <slot />
    </div>
    {footerMode !== "none" && <QuietFooter />}
  </div>
</Layout>
