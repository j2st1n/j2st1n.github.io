---
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import { SITE } from "@/config";
---

<QuietLayout showHeader={false} footerMode="none" title={`404 | ${SITE.title}`} description="页面不见了。" noindex>
  <main class="fish-page" aria-labelledby="lost-title">
    <section class="lost-card">
      <p class="error-code">404</p>
      <h1 id="lost-title">鱼呢？</h1>
      <p class="lost-copy">也许它顺着水流去了别处，也许它从来没在这里。</p>
      <nav class="lost-links" aria-label="404 navigation">
        <a href="/">HOME</a>
        <span aria-hidden="true">/</span>
        <a href="/archives">ARCHIVE</a>
        <span aria-hidden="true">/</span>
        <a href="/search">SEARCH</a>
      </nav>
    </section>
  </main>
</QuietLayout>

<style>
  .fish-page { min-height: 100svh; overflow: hidden; background: var(--background); color: var(--foreground); display: grid; place-items: center; padding: clamp(2rem, 7svh, 4rem) 1rem; position: relative; }
  .lost-card { width: min(100%, 35rem); margin: 0 auto; text-align: center; position: relative; z-index: 1; animation: surface-copy 1.4s ease 0.2s both; }
  .error-code { margin: 0 0 1.1rem; color: var(--text-muted); font-size: 0.88rem; font-weight: 620; letter-spacing: 0.22em; }
  .lost-card h1 { margin: 0; color: var(--foreground); font-size: clamp(2rem, 5vw, 3.35rem); font-weight: 640; line-height: 1.08; letter-spacing: -0.06em; text-wrap: balance; }
  .lost-copy { max-width: 27rem; margin: 1.75rem auto 0; color: var(--text-muted); font-size: clamp(1rem, 2.3vw, 1.12rem); line-height: 1.95; text-wrap: balance; }
  .lost-links { margin-top: clamp(3.25rem, 10svh, 5rem); display: inline-flex; align-items: center; justify-content: center; gap: 0.65rem; flex-wrap: wrap; color: var(--text-muted); font-size: 0.88rem; font-weight: 620; letter-spacing: 0.14em; }
  .lost-links a { color: inherit; text-decoration: none; text-underline-offset: 0.35em; transition: color 0.2s ease, text-decoration-color 0.2s ease; }
  .lost-links a:hover, .lost-links a:focus-visible { color: var(--accent); text-decoration: underline; text-decoration-style: dotted; }
  .lost-links span { color: color-mix(in oklch, var(--text-muted), transparent 42%); }
  @keyframes surface-copy { from { opacity: 0; transform: translateY(0.75rem); } to { opacity: 1; transform: translateY(0); } }
  @media (max-width: 640px) { .lost-card { text-align: left; } .lost-card h1 { font-size: clamp(2rem, 12vw, 2.7rem); letter-spacing: -0.035em; text-wrap: wrap; } .lost-copy { margin-left: 0; text-wrap: wrap; } .lost-links { justify-content: flex-start; gap: 0.5rem; } }
  @media (prefers-reduced-motion: reduce) { .lost-card { animation: none; } }
</style>
