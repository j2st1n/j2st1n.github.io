---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getPostsByTag from "@/utils/getPostsByTag";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);

const tagSummaries = tags
  .map(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    const latestPost = tagPosts[0];

    return {
      tag,
      tagName,
      count: tagPosts.length,
      latestPost,
    };
  })
  .sort((tagA, tagB) => {
    if (tagB.count !== tagA.count) return tagB.count - tagA.count;
    return tagA.tagName.localeCompare(tagB.tagName);
  });

const frequentTagSummaries = tagSummaries.filter(({ count }) => count > 1);
const primaryTagSummaries = frequentTagSummaries.length > 0 ? frequentTagSummaries : tagSummaries.slice(0, 12);
const hiddenTagCount = tagSummaries.length - primaryTagSummaries.length;

const latestDate = posts.length
  ? dayjs(
      posts
        .map(post => post.data.modDatetime ?? post.data.pubDatetime)
        .sort((dateA, dateB) => dateB.getTime() - dateA.getTime())[0]
    )
      .tz(SITE.timezone)
      .format("YYYY.MM.DD")
  : "";

const formatFullDate = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("YYYY.MM.DD");
---

<QuietLayout title={`标签 | ${SITE.title}`} description="所有文章标签的轻量索引。">

  <main id="main-content" class="tags-page">
    <header class="tags-hero">
      <p class="tags-kicker">Tags</p>
      <h1>主题索引</h1>
      <p>
        展示 {primaryTagSummaries.length} 个高频标签
        <span> · 共 {tagSummaries.length} 个标签</span>
        <span> · {posts.length} 篇文章</span>
        {latestDate && <span> · 最近更新 {latestDate}</span>}
      </p>
    </header>

    <section class="tag-index" aria-label="标签索引">
      <ul class="tag-list">
        {primaryTagSummaries.map(({ tag, tagName, count, latestPost }) => (
          <li class="tag-item">
            <a href={`/tags/${tag}/`} class="tag-link">
              <span class="tag-name">{tagName}</span>
              <span class="tag-count">{count} 篇</span>
              {latestPost && (
                <span class="tag-latest">
                  <span class="tag-latest-label">最近</span>
                  <span class="tag-latest-title">{latestPost.data.title}</span>
                  <time datetime={new Date(latestPost.data.pubDatetime).toISOString()}>
                    {formatFullDate(latestPost.data.pubDatetime)}
                  </time>
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
      {hiddenTagCount > 0 && (
        <p class="tag-note">
          <a href="/all-tags">全部标签 →</a>
        </p>
      )}
    </section>

  </main>
</QuietLayout>

<style>
  .tags-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .tags-hero {
    padding-bottom: 2.75rem;
    border-bottom: 1px solid var(--border-color);
  }

  .tags-kicker {
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--foreground);
    opacity: 0.32;
  }

  .tags-hero h1 {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.08;
    font-weight: 650;
    letter-spacing: -0.055em;
    color: var(--foreground);
  }

  .tags-hero p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--foreground);
    opacity: 0.46;
  }

  .tag-index {
    padding: 0.75rem 0 1.5rem;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-item {
    border-bottom: 1px solid var(--border-color);
  }

  .tag-link {
    display: grid;
    grid-template-columns: minmax(8rem, 0.8fr) 4rem minmax(0, 1.7fr);
    gap: 1.25rem;
    align-items: baseline;
    padding: 1.15rem 0;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .tag-link:hover {
    transform: translateX(2px);
  }

  .tag-link:hover .tag-name,
  .tag-link:hover .tag-latest-title {
    color: var(--accent);
  }

  .tag-name {
    min-width: 0;
    font-size: 1.125rem;
    line-height: 1.35;
    font-weight: 540;
    color: var(--foreground);
    overflow-wrap: anywhere;
    transition: color 0.2s ease;
  }

  .tag-count {
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.42;
    white-space: nowrap;
  }

  .tag-latest {
    min-width: 0;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 0.625rem;
    align-items: baseline;
    color: var(--foreground);
  }

  .tag-latest-label,
  .tag-latest time {
    font-size: 0.75rem;
    opacity: 0.36;
    white-space: nowrap;
  }

  .tag-latest-title {
    min-width: 0;
    font-size: 0.875rem;
    line-height: 1.45;
    opacity: 0.66;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .tag-note {
    margin-top: 1.25rem;
    max-width: 34rem;
    font-size: 0.8125rem;
    line-height: 1.75;
    color: var(--foreground);
    opacity: 0.48;
  }

  .tag-note a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklch, currentColor, transparent 68%);
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .tag-note a:hover {
    color: var(--accent);
    opacity: 1;
  }

  .separator {
    margin: 0 0.375rem;
    opacity: 0.4;
  }

  @media (max-width: 700px) {
    .tag-link {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.5rem 1rem;
      align-items: start;
    }

    .tag-name {
      font-size: 1rem;
    }

    .tag-count {
      padding-top: 0.1rem;
      text-align: right;
    }

    .tag-latest {
      grid-column: 1 / -1;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.4rem 0.625rem;
    }

    .tag-latest time {
      grid-column: 2;
    }
  }

  @media (max-width: 640px) {
    .tags-page {
      padding: 1.5rem 1rem 3rem;
    }

    .tags-hero {
      padding-bottom: 2rem;
    }

    .tags-hero h1 {
      font-size: 2.25rem;
    }
  }
</style>
