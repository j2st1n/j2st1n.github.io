---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getPostsByTag from "@/utils/getPostsByTag";
import getUniqueTags from "@/utils/getUniqueTags";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  tagName: string;
  posts: Awaited<ReturnType<typeof getCollection<"blog">>>;
};

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = getUniqueTags(posts);

  return tags.map(({ tag, tagName }) => ({
    params: { tag },
    props: { tagName, posts: getPostsByTag(posts, tag) },
  }));
}

const { tagName, posts } = Astro.props;
const latestDate = posts.length
  ? dayjs(posts[0].data.modDatetime ?? posts[0].data.pubDatetime).tz(SITE.timezone).format("YYYY.MM.DD")
  : "";

const formatFullDate = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("YYYY.MM.DD");
---

<QuietLayout title={`${tagName} | ${SITE.title}`} description={`包含标签「${tagName}」的所有文章。`}>
  <main id="main-content" class="content-page">
    <header class="page-hero">
      <div class="hero-line">
        <p class="page-kicker">Tag</p>
        <a href="/tags" class="all-tags-link">全部主题 →</a>
      </div>
      <h1>{tagName}</h1>
      <p>
        {posts.length} 篇文章
        {latestDate && <span> · 最近更新 {latestDate}</span>}
      </p>
    </header>

    <section class="post-index" aria-label={`${tagName} 标签文章列表`}>
      <ul class="post-list">
        {posts.map(post => (
          <li class="post-item">
            <a href={getPath(post.id, post.filePath)} class="post-link">
              <time datetime={new Date(post.data.pubDatetime).toISOString()}>
                {formatFullDate(post.data.pubDatetime)}
              </time>
              <span class="post-content">
                <span class="post-title">{post.data.title}</span>
                {post.data.description && <span class="post-desc">{post.data.description}</span>}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </main>
</QuietLayout>

<style>
  .content-page {
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 5rem 1rem 3rem;
    color: var(--foreground);
  }

  .page-hero {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-line {
    margin: 0 0 0.75rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .page-kicker {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .all-tags-link {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.7;
    text-decoration: none;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .all-tags-link:hover {
    color: var(--accent);
    transform: translateX(0.125rem);
  }

  .page-hero h1 {
    margin: 0;
    color: var(--foreground);
    font-size: clamp(2rem, 7vw, 4.5rem);
    font-weight: 680;
    line-height: 0.98;
    letter-spacing: -0.065em;
    text-wrap: balance;
  }

  .page-hero p {
    margin: 1.25rem 0 0;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  .post-index {
    padding-top: 2rem;
  }

  .post-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-item + .post-item {
    border-top: 1px solid var(--border-color);
  }

  .post-link {
    display: grid;
    grid-template-columns: 7.5rem minmax(0, 1fr);
    gap: 1.5rem;
    padding: 1.1rem 0;
    color: inherit;
    text-decoration: none;
  }

  .post-link time {
    color: var(--text-muted);
    font-size: 0.8125rem;
    line-height: 1.7;
    font-variant-numeric: tabular-nums;
  }

  .post-content {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
  }

  .post-title {
    color: var(--foreground);
    font-size: 1.05rem;
    font-weight: 560;
    line-height: 1.65;
    letter-spacing: -0.025em;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .post-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.8;
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .post-link:hover .post-title {
    color: var(--accent);
    transform: translateX(0.125rem);
  }

  @media (max-width: 640px) {
    .content-page {
      padding-top: 3.75rem;
    }

    .hero-line {
      align-items: center;
    }

    .all-tags-link {
      font-size: 0.8125rem;
    }

    .post-link {
      grid-template-columns: 1fr;
      gap: 0.2rem;
      padding: 1rem 0;
    }

    .post-link time {
      font-size: 0.75rem;
    }

    .page-hero h1 {
      letter-spacing: -0.035em;
      text-wrap: wrap;
    }
  }
</style>
