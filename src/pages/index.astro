---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);

// 规则：有置顶用置顶，没有置顶用最新
const featuredPost =
  sortedPosts.find(({ data }) => data.featured) ?? sortedPosts[0];
// 最近文章排除主推，最多 6 篇
const recentPosts = sortedPosts
  .filter(post => post.id !== featuredPost?.id)
  .slice(0, 6);

// 最近更新日期
const latestDate = sortedPosts[0]
  ? dayjs(sortedPosts[0].data.modDatetime ?? sortedPosts[0].data.pubDatetime)
      .tz(SITE.timezone)
      .format("YYYY.MM.DD")
  : "";

// 格式化日期
const formatMonth = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("M月");

const formatDay = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("D日");

const formatFullDate = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("YYYY.MM.DD");
---

<QuietLayout title={`${SITE.title} | ${SITE.desc}`}>
  <main id="main-content" class="home-page">
    <!-- 01 顶部个人开场 -->
    <section class="hero">
      <h1 class="hero-subtitle">随便写写，认真存档。</h1>
      <div class="hero-meta">
        <span data-blog-uptime data-start="2026-03-15T08:32:01+08:00">
          已摸鱼计算中…
        </span>
        <span class="separator">·</span>
        <span class="hero-stats">
          共 {sortedPosts.length} 篇文章
          {latestDate && <span> · 最近更新 {latestDate}</span>}
        </span>
      </div>
    </section>

    <!-- 02 主推文章 -->
    {
      featuredPost && (
        <section class="featured">
          <a
            href={getPath(featuredPost.id, featuredPost.filePath)}
            class="featured-link"
          >
            <span class="featured-marker" aria-hidden="true">
              01
            </span>
            <div class="featured-body">
              <h2 class="featured-title">{featuredPost.data.title}</h2>
              {featuredPost.data.description && (
                <p class="featured-desc">{featuredPost.data.description}</p>
              )}
              <div class="featured-meta">
                <time
                  datetime={new Date(
                    featuredPost.data.pubDatetime
                  ).toISOString()}
                >
                  {formatFullDate(featuredPost.data.pubDatetime)}
                </time>
                {featuredPost.data.tags?.length > 0 && (
                  <>
                    <span class="separator">·</span>
                    <span class="featured-tags">
                      {featuredPost.data.tags.slice(0, 2).join(" / ")}
                    </span>
                  </>
                )}
              </div>
            </div>
          </a>
        </section>
      )
    }

    <!-- 03 最近文章 -->
    {
      recentPosts.length > 0 && (
        <section class="recent">
          <div class="section-head">
            <div class="section-label">最近文章</div>
            <a href="/archives" class="section-action">
              全部文章 <span class="arrow">→</span>
            </a>
          </div>
          <ul class="recent-list">
            {recentPosts.map(post => (
              <li class="recent-item">
                <a href={getPath(post.id, post.filePath)} class="recent-link">
                  <span class="recent-date">
                    <span class="recent-date-month">
                      {formatMonth(post.data.pubDatetime)}
                    </span>
                    <span class="recent-date-day">
                      {formatDay(post.data.pubDatetime)}
                    </span>
                  </span>
                  <div class="recent-content">
                    <span class="recent-title">{post.data.title}</span>
                    {post.data.description && (
                      <span class="recent-desc">{post.data.description}</span>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- 04 页脚 -->
  </main>
</QuietLayout>

<style>
  /* ===== 安静索引 / Quiet Index ===== */

  .home-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  /* --- 01 顶部个人开场 --- */
  .hero {
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--foreground);
    opacity: 0.75;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.42;
  }

  /* --- 通用 --- */
  .separator {
    margin: 0 0.375rem;
    opacity: 0.4;
  }

  /* --- 02 当前推荐 --- */
  .featured {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .featured-link {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr);
    gap: 1.25rem;
    align-items: start;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .featured-link:hover {
    transform: translateX(2px);
  }

  .featured-link:hover .featured-title {
    color: var(--accent);
  }

  .featured-marker {
    display: block;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    line-height: 2.025rem;
    color: var(--foreground);
    opacity: 0.24;
    letter-spacing: 0.08em;
  }

  .featured-body {
    min-width: 0;
  }

  .featured-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--foreground);
    margin-bottom: 0.75rem;
    transition: color 0.2s ease;
  }

  .featured-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--foreground);
    opacity: 0.65;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-meta {
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.45;
  }

  .featured-tags {
    opacity: 0.8;
  }

  /* --- 03 最近文章 --- */
  .recent {
    padding: 2.5rem 0;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .section-action {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--foreground);
    opacity: 0.52;
    text-decoration: none;
    font-size: 0.8125rem;
    transition:
      opacity 0.2s ease,
      color 0.2s ease,
      gap 0.2s ease;
  }

  .section-action:hover {
    opacity: 1;
    color: var(--accent);
    gap: 0.55rem;
  }

  .recent-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .recent-item {
    border-bottom: 1px solid var(--border-color);
  }

  .recent-item:last-child {
    border-bottom: none;
  }

  .recent-link {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.125rem 0;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease;
  }

  .recent-link:hover {
    transform: translateX(2px);
  }

  .recent-link:hover .recent-title {
    color: var(--accent);
  }

  .recent-date {
    flex-shrink: 0;
    width: 3.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.0625rem;
    padding-top: 0.375rem;
    font-variant-numeric: tabular-nums;
    color: var(--foreground);
    text-align: right;
  }

  .recent-date-month {
    font-size: 0.6875rem;
    line-height: 1;
    opacity: 0.34;
  }

  .recent-date-day {
    font-size: 0.9375rem;
    line-height: 1.1;
    opacity: 0.48;
    letter-spacing: -0.02em;
  }

  .recent-content {
    flex: 1;
    min-width: 0;
  }

  .recent-title {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--foreground);
    transition: color 0.2s ease;
  }

  .recent-desc {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--foreground);
    opacity: 0.5;
    margin-top: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .arrow {
    transition: transform 0.2s ease;
  }

  .section-action:hover .arrow {
    transform: translateX(2px);
  }

  /* --- 移动端适配 --- */
  @media (max-width: 640px) {
    .home-page {
      padding: 1.5rem 1rem 3rem;
    }

    .hero {
      padding-bottom: 2rem;
    }

    .hero-subtitle {
      font-size: 1.125rem;
    }

    .featured {
      padding: 2rem 0;
    }

    .featured-title {
      font-size: 1.25rem;
    }

    .featured-marker {
      line-height: 1.6875rem;
    }

    .recent {
      padding: 2rem 0;
    }

    .recent-link {
      gap: 0.875rem;
    }

    .recent-date {
      width: 2.75rem;
      align-items: flex-start;
      text-align: left;
    }

    .featured-link {
      grid-template-columns: 2.75rem minmax(0, 1fr);
      gap: 0.875rem;
    }

    .recent-desc {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
  }

  /* --- 暗色模式微调 --- */
  :global(html[data-theme="dark"]) .featured-title,
  :global(html[data-theme="dark"]) .recent-title {
    color: var(--foreground);
  }

  :global(html[data-theme="dark"]) .featured-link:hover .featured-title,
  :global(html[data-theme="dark"]) .recent-link:hover .recent-title {
    color: var(--accent);
  }
</style>

<script is:inline>
  const init = () => {
    const el = document.querySelector("[data-blog-uptime]");
    if (!el) return;

    const start = el.getAttribute("data-start");
    if (!start) return;

    const startDate = new Date(start);
    if (Number.isNaN(startDate.getTime())) return;

    const diffParts = (from, to) => {
      let cursor = new Date(from);
      let years = 0;
      while (true) {
        const next = new Date(cursor);
        next.setFullYear(next.getFullYear() + 1);
        if (next <= to) {
          years += 1;
          cursor = next;
        } else break;
      }
      let months = 0;
      while (true) {
        const next = new Date(cursor);
        next.setMonth(next.getMonth() + 1);
        if (next <= to) {
          months += 1;
          cursor = next;
        } else break;
      }
      let rest = Math.max(0, to.getTime() - cursor.getTime());
      const days = Math.floor(rest / 86400000);
      rest -= days * 86400000;
      const hours = Math.floor(rest / 3600000);
      rest -= hours * 3600000;
      const minutes = Math.floor(rest / 60000);
      rest -= minutes * 60000;
      const seconds = Math.floor(rest / 1000);
      return { years, months, days, hours, minutes, seconds };
    };

    const render = () => {
      const now = new Date();
      const { years, months, days, hours, minutes, seconds } = diffParts(
        startDate,
        now
      );
      const parts = [];
      if (years > 0) parts.push(`${years}年`);
      if (months > 0) parts.push(`${months}个月`);
      if (days > 0) parts.push(`${days}天`);
      if (hours > 0) parts.push(`${hours}小时`);
      if (minutes > 0) parts.push(`${minutes}分钟`);
      parts.push(`${seconds}秒`);
      el.textContent = `已摸鱼 ${parts.join("")}`;
    };

    clearInterval(window.__blogUptimeTimer);
    render();
    window.__blogUptimeTimer = setInterval(render, 1000);
  };

  document.addEventListener("astro:page-load", init);
  init();
</script>
