---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog", ({ data }) => !data.draft);

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const normalPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <div class="pt-8" />

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pb-6",
            { "border-b border-border": normalPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">置顶</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      normalPosts.length > 0 && (
        <section id="posts" class="pt-8 pb-6">
          <ul>
            {normalPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <section class="my-10 rounded-2xl border border-border bg-card/40 px-5 py-6 text-center">
      <div class="mx-auto max-w-2xl space-y-3">
        <p class="text-sm tracking-wide text-muted-foreground uppercase">摸鱼推荐</p>
        <h2 class="text-2xl font-semibold">来玩我做的修仙互动小说</h2>
        <p class="text-muted-foreground">
          一边摸鱼，一边修仙。点进去，你的每个选择都会改命。
        </p>
        <div class="pt-2">
          <LinkButton
            href="https://xiuxian.bins.blog"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent"
          >
            立即开修
            <IconArrowRight class="inline-block rtl:-rotate-180" />
          </LinkButton>
        </div>
      </div>
    </section>

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        全部文章
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const main = document.querySelector("#main-content") as HTMLElement | null;
    const indexLayout = main?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
