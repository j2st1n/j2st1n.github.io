---
import { getCollection } from "astro:content";
import QuietPostDetails from "@/themes/quiet/layouts/QuietPostDetails.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const previewPost = sortedPosts.find(({ data }) => data.featured) ?? sortedPosts[0];

if (!previewPost) {
  throw new Error("No published posts available for article preview.");
}
---

<QuietPostDetails post={previewPost} posts={sortedPosts} titleSuffix="文章详情预览" />
