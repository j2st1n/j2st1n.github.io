---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getQuietPath } from "@/utils/getQuietPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);

const latestDate = sortedPosts[0]
  ? dayjs(sortedPosts[0].data.modDatetime ?? sortedPosts[0].data.pubDatetime)
      .tz(SITE.timezone)
      .format("YYYY.MM.DD")
  : "";

const latestYear = sortedPosts[0]
  ? dayjs(sortedPosts[0].data.pubDatetime).tz(SITE.timezone).format("YYYY")
  : "";

const latestMonth = sortedPosts[0]
  ? dayjs(sortedPosts[0].data.pubDatetime).tz(SITE.timezone).format("M月")
  : "";

const formatYear = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("YYYY");

const formatMonth = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("M月");

const formatDay = (date: string | Date) =>
  dayjs(date).tz(SITE.timezone).format("D日");

const groupedPosts = sortedPosts.reduce(
  (years, post) => {
    const year = formatYear(post.data.pubDatetime);
    const month = formatMonth(post.data.pubDatetime);

    years[year] ??= { count: 0, months: {} };
    years[year].count += 1;
    years[year].months[month] ??= [];
    years[year].months[month].push(post);

    return years;
  },
  {} as Record<string, { count: number; months: Record<string, typeof sortedPosts> }>
);

const yearGroups = Object.entries(groupedPosts).sort(
  ([yearA], [yearB]) => Number(yearB) - Number(yearA)
);
---

<QuietLayout title={`归档预览 | ${SITE.title}`} description="所有已发布文章的时间索引预览。">

  <main id="main-content" class="archive-preview">
    <header class="archive-hero">
      <p class="archive-kicker">Archive</p>
      <h1>认真存档</h1>
      <p>
        共 {sortedPosts.length} 篇文章
        {latestDate && <span> · 最近更新 {latestDate}</span>}
      </p>
    </header>

    <section class="archive-index" aria-label="文章归档索引">
      {yearGroups.map(([year, yearGroup]) => (
        <section class="year-block" aria-labelledby={`archive-${year}`}>
          <header class="year-head">
            <h2 id={`archive-${year}`}>{year}</h2>
            <span>{yearGroup.count} 篇</span>
          </header>
          <div class="month-groups">
            {Object.entries(yearGroup.months)
              .sort(([monthA], [monthB]) => Number.parseInt(monthB) - Number.parseInt(monthA))
              .map(([month, monthPosts]) => (
                <details class="month-block" open={year === latestYear && month === latestMonth}>
                  <summary class="month-summary">
                    <span class="month-label">{month}</span>
                    <span class="month-count">{monthPosts.length} 篇</span>
                    <span class="month-toggle" aria-hidden="true">展开</span>
                  </summary>
                  <ul class="post-list" aria-label={`${year} ${month}文章`}>
                    {monthPosts.map(post => (
                      <li class="post-item">
                        <a href={getQuietPath(post.id, post.filePath)} class="post-link">
                          <time datetime={new Date(post.data.pubDatetime).toISOString()} class="post-date">
                            {formatDay(post.data.pubDatetime)}
                          </time>
                          <span class="post-content">
                            <span class="post-title">{post.data.title}</span>
                            {post.data.description && (
                              <span class="post-desc">{post.data.description}</span>
                            )}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
          </div>
        </section>
      ))}
    </section>

  </main>
</QuietLayout>

<style>
  .archive-preview {
    max-width: var(--preview-width);
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .archive-hero {
    padding-bottom: 2.75rem;
    border-bottom: 1px solid var(--preview-line);
  }

  .archive-kicker {
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--foreground);
    opacity: 0.32;
  }

  .archive-hero h1 {
    margin-bottom: 1rem;
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.08;
    font-weight: 650;
    letter-spacing: -0.055em;
    color: var(--foreground);
  }

  .archive-hero p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--foreground);
    opacity: 0.46;
  }

  .archive-index {
    padding: 0.75rem 0 1.5rem;
  }

  .year-block {
    padding: 2.25rem 0;
    border-bottom: 1px solid var(--preview-line);
  }

  .year-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .year-head h2 {
    font-size: 1.75rem;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--foreground);
  }

  .year-head span {
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.42;
  }

  .month-block {
    border-top: 1px solid var(--preview-line);
  }

  .month-block:first-child {
    border-top: none;
  }

  .month-summary {
    display: grid;
    grid-template-columns: 4.5rem 1fr auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1rem 0;
    color: inherit;
    cursor: pointer;
    list-style: none;
  }

  .month-summary::-webkit-details-marker {
    display: none;
  }

  .month-label {
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.46;
    font-variant-numeric: tabular-nums;
  }

  .month-count,
  .month-toggle {
    font-size: 0.8125rem;
    color: var(--foreground);
    opacity: 0.38;
  }

  .month-toggle {
    transition: color 0.2s ease, opacity 0.2s ease;
  }

  .month-block[open] .month-toggle {
    opacity: 0.54;
  }

  .month-block[open] .month-toggle::before {
    content: "收起";
  }

  .month-block[open] .month-toggle {
    font-size: 0;
  }

  .month-block[open] .month-toggle::before {
    font-size: 0.8125rem;
  }

  .month-summary:hover .month-label,
  .month-summary:hover .month-toggle {
    color: var(--accent);
    opacity: 1;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem 6rem;
  }

  .post-item {
    border-bottom: 1px solid var(--preview-line);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-link {
    display: grid;
    grid-template-columns: 3.25rem minmax(0, 1fr);
    gap: 1.25rem;
    padding: 0.95rem 0;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .post-link:hover {
    transform: translateX(2px);
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-date {
    padding-top: 0.2rem;
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--foreground);
    opacity: 0.42;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .post-content {
    min-width: 0;
  }

  .post-title {
    display: block;
    font-size: 1rem;
    line-height: 1.55;
    font-weight: 500;
    color: var(--foreground);
    transition: color 0.2s ease;
  }

  .post-desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--foreground);
    opacity: 0.48;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .archive-preview {
      padding: 1.5rem 1rem 3rem;
    }

    .archive-hero {
      padding-bottom: 2rem;
    }

    .archive-hero h1 {
      font-size: 2.25rem;
    }

    .year-block {
      padding: 1.75rem 0;
    }

    .month-summary {
      grid-template-columns: 3.25rem 1fr auto;
      gap: 0.875rem;
      padding: 0.875rem 0;
    }

    .month-label,
    .month-count,
    .month-toggle,
    .month-block[open] .month-toggle::before {
      font-size: 0.75rem;
    }

    .post-list {
      margin-left: 0;
      margin-bottom: 0.875rem;
    }

    .post-link {
      grid-template-columns: 2.75rem minmax(0, 1fr);
      gap: 0.875rem;
    }

    .post-desc {
      white-space: normal;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

  }
</style>
