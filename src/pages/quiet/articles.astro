---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getQuietPath } from "@/utils/getQuietPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const latestDate = sortedPosts[0]
  ? dayjs(sortedPosts[0].data.modDatetime ?? sortedPosts[0].data.pubDatetime).tz(SITE.timezone).format("YYYY.MM.DD")
  : "";
const formatFullDate = (date: string | Date) => dayjs(date).tz(SITE.timezone).format("YYYY.MM.DD");
---

<QuietLayout title={`全部文章预览 | ${SITE.title}`} description="全部文章的索引式预览。">

  <main id="main-content" class="preview-page">
    <header class="page-hero">
      <p class="page-kicker">Posts</p>
      <h1>全部文章</h1>
      <p>
        共 {sortedPosts.length} 篇文章
        {latestDate && <span> · 最近更新 {latestDate}</span>}
      </p>
    </header>

    <section class="article-index" aria-label="全部文章索引">
      <ul class="article-list">
        {sortedPosts.map(post => (
          <li class="article-item">
            <a href={getQuietPath(post.id, post.filePath)} class="article-link">
              <time datetime={new Date(post.data.pubDatetime).toISOString()} class="article-date">
                {formatFullDate(post.data.pubDatetime)}
              </time>
              <span class="article-content">
                <span class="article-title">{post.data.title}</span>
                {post.data.description && <span class="article-desc">{post.data.description}</span>}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </main>
</QuietLayout>

<style>
  .preview-page { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 5rem 1rem 3rem; color: var(--foreground); }
  .page-hero { padding-bottom: 2.5rem; border-bottom: 1px solid var(--preview-line); }
  .page-kicker { margin: 0 0 0.75rem; color: var(--preview-muted); font-size: 0.75rem; line-height: 1; letter-spacing: 0.12em; text-transform: uppercase; }
  .page-hero h1 { margin: 0; color: var(--foreground); font-size: clamp(2rem, 7vw, 4.5rem); font-weight: 680; line-height: 0.98; letter-spacing: -0.065em; }
  .page-hero p { max-width: 34rem; margin: 1.25rem 0 0; color: var(--preview-muted); font-size: 0.9375rem; line-height: 1.8; }
  .article-index { padding: 2.25rem 0 0; }
  .article-list { margin: 0; padding: 0; list-style: none; }
  .article-item + .article-item { border-top: 1px solid var(--preview-line); }
  .article-link { display: grid; grid-template-columns: 7.5rem minmax(0, 1fr); gap: 1.5rem; padding: 1.1rem 0; color: inherit; text-decoration: none; }
  .article-date { color: var(--preview-muted); font-size: 0.8125rem; line-height: 1.7; font-variant-numeric: tabular-nums; }
  .article-content { display: grid; gap: 0.35rem; min-width: 0; }
  .article-title { color: var(--foreground); font-size: 1.05rem; font-weight: 560; line-height: 1.65; letter-spacing: -0.025em; transition: color 0.2s ease, transform 0.2s ease; }
  .article-desc { color: var(--preview-muted); font-size: 0.875rem; line-height: 1.8; display: -webkit-box; overflow: hidden; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .article-link:hover .article-title { color: var(--accent); transform: translateX(0.125rem); }
  @media (max-width: 640px) { .preview-page { padding-top: 3.75rem; } .article-link { grid-template-columns: 1fr; gap: 0.2rem; padding: 1rem 0; } .article-date { font-size: 0.75rem; } }
</style>
