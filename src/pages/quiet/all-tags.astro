---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getPostsByTag from "@/utils/getPostsByTag";
import getUniqueTags from "@/utils/getUniqueTags";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tags = getUniqueTags(posts);
const tagSummaries = tags
  .map(({ tag, tagName }) => ({ tag, tagName, count: getPostsByTag(posts, tag).length }))
  .sort((tagA, tagB) => tagB.count - tagA.count || tagA.tagName.localeCompare(tagB.tagName));
const latestDate = posts.length
  ? dayjs(posts.map(post => post.data.modDatetime ?? post.data.pubDatetime).sort((a, b) => b.getTime() - a.getTime())[0]).tz(SITE.timezone).format("YYYY.MM.DD")
  : "";
---

<QuietLayout title={`全部标签预览 | ${SITE.title}`} description="全部标签的轻量索引预览。">

  <main id="main-content" class="preview-page">
    <header class="page-hero"><p class="page-kicker">Tags</p><h1>全部标签</h1><p>共 {tagSummaries.length} 个标签<span> · {posts.length} 篇文章</span>{latestDate && <span> · 最近更新 {latestDate}</span>}</p></header>
    <section class="tags-grid" aria-label="全部标签索引">
      {tagSummaries.map(({ tag, tagName, count }) => (
        <a href={`/quiet/tags/${tag}/`} class="tag-pill"><span>{tagName}</span><small>{count} 篇</small></a>
      ))}
    </section>
  </main>
</QuietLayout>

<style>
  :global(html) { --preview-width: 48rem; --preview-line: oklch(88% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 48%); }
  :global(html[data-theme="dark"]) { --preview-line: oklch(31% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 38%); }
  .preview-skip { position: absolute; inset-inline-start: 1rem; top: -100%; z-index: 50; padding: 0.5rem 0.75rem; background: var(--background); color: var(--accent); transition: top 0.2s ease; }
  .preview-skip:focus { top: 1rem; }
  .preview-header { width: 100%; padding-top: 1.5rem; }
  .preview-header-inner { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 0 1rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .preview-brand { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--foreground); text-decoration: none; font-size: 1.25rem; font-weight: 650; line-height: 1; letter-spacing: -0.03em; }
  .brand-logo { width: 2rem; height: 2rem; flex-shrink: 0; }
  .preview-tools { display: inline-flex; align-items: center; gap: 0.375rem; }
  .tool-link, .theme-button { width: 2rem; height: 2rem; display: inline-flex; align-items: center; justify-content: center; color: var(--foreground); opacity: 0.58; border: 0; border-radius: 999px; background: transparent; cursor: pointer; transition: opacity 0.2s ease, color 0.2s ease, background-color 0.2s ease; }
  .tool-link:hover, .theme-button:hover { opacity: 1; color: var(--accent); background: color-mix(in oklch, var(--accent), transparent 92%); }
  .tool-link svg, .theme-button svg { width: 1.125rem; height: 1.125rem; }
  .theme-button { position: relative; }
  .theme-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); transition: transform 0.2s ease, opacity 0.2s ease; }
  .sun-icon { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .moon-icon { opacity: 0; transform: translate(-50%, -50%) rotate(-90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .sun-icon { opacity: 1; transform: translate(-50%, -50%) rotate(0) scale(1); }
  .preview-page { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 5rem 1rem 3rem; color: var(--foreground); }
  .page-hero { padding-bottom: 2.5rem; border-bottom: 1px solid var(--preview-line); }
  .page-kicker { margin: 0 0 0.75rem; color: var(--preview-muted); font-size: 0.75rem; line-height: 1; letter-spacing: 0.12em; text-transform: uppercase; }
  .page-hero h1 { margin: 0; color: var(--foreground); font-size: clamp(2rem, 7vw, 4.5rem); font-weight: 680; line-height: 0.98; letter-spacing: -0.065em; }
  .page-hero p { max-width: 34rem; margin: 1.25rem 0 0; color: var(--preview-muted); font-size: 0.9375rem; line-height: 1.8; }
  .tags-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0; padding-top: 2.25rem; }
  .tag-pill { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; padding: 0.95rem 0; color: inherit; text-decoration: none; border-bottom: 1px solid var(--preview-line); }
  .tag-pill:nth-child(odd) { padding-right: 1rem; }
  .tag-pill:nth-child(even) { padding-left: 1rem; }
  .tag-pill span { color: var(--foreground); font-size: 1rem; font-weight: 560; line-height: 1.6; letter-spacing: -0.025em; transition: color 0.2s ease, transform 0.2s ease; }
  .tag-pill small { color: var(--preview-muted); font-size: 0.8125rem; white-space: nowrap; }
  .tag-pill:hover span { color: var(--accent); transform: translateX(0.125rem); }
  .separator { color: color-mix(in oklch, var(--preview-muted), transparent 42%); }
  @media (max-width: 640px) { .preview-page { padding-top: 3.75rem; } .tags-grid { grid-template-columns: 1fr; } .tag-pill:nth-child(n) { padding-left: 0; padding-right: 0; } }
</style>
