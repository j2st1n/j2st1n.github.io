---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import QuietFooter from "@/themes/quiet/components/QuietFooter.astro";
import IconSearch from "@/assets/icons/IconSearch.svg";
import getSortedPosts from "@/utils/getSortedPosts";
import { getQuietPath } from "@/utils/getQuietPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts);
const searchItems = sortedPosts.map(post => ({
  title: post.data.title,
  description: post.data.description ?? "",
  date: dayjs(post.data.pubDatetime).tz(SITE.timezone).format("YYYY.MM.DD"),
  href: getQuietPath(post.id, post.filePath),
  tags: post.data.tags ?? [],
}));
---

<QuietLayout title={`搜索预览 | ${SITE.title}`} description="搜索页和搜索结果的预览。">

  <main id="main-content" class="preview-page">
    <section class="search-panel" aria-label="文章搜索">
      <label class="search-box"><IconSearch aria-hidden="true" /><span class="placeholder-variant" aria-hidden="true">摸一摸</span><input id="preview-search-input" type="search" aria-label="搜索文章" autocomplete="off" placeholder=" " autofocus /></label>
      <p class="search-count" hidden><span id="preview-search-count">找到 0 个结果</span></p>
      <ul class="result-list" id="preview-search-results">
        {searchItems.map(item => (
          <li class="result-item" hidden data-title={item.title.toLowerCase()} data-desc={item.description.toLowerCase()} data-tags={item.tags.join(" ").toLowerCase()}>
            <a href={item.href} class="result-link"><time>{item.date}</time><span class="result-content"><span class="result-title">{item.title}</span>{item.description && <span class="result-desc">{item.description}</span>}</span></a>
          </li>
        ))}
      </ul>
    </section>
    <QuietFooter />
  </main>
</QuietLayout>

<style>
  :global(html) { --preview-width: 48rem; --preview-line: oklch(88% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 48%); }
  :global(html[data-theme="dark"]) { --preview-line: oklch(31% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 38%); }
  .preview-skip { position: absolute; inset-inline-start: 1rem; top: -100%; z-index: 50; padding: 0.5rem 0.75rem; background: var(--background); color: var(--accent); transition: top 0.2s ease; }
  .preview-skip:focus { top: 1rem; }
  .preview-header { width: 100%; padding-top: 1.5rem; }
  .preview-header-inner { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 0 1rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .preview-brand { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--foreground); text-decoration: none; font-size: 1.25rem; font-weight: 650; line-height: 1; letter-spacing: -0.03em; }
  .brand-logo { width: 2rem; height: 2rem; flex-shrink: 0; }
  .preview-tools { display: inline-flex; align-items: center; gap: 0.375rem; }
  .tool-link, .theme-button { width: 2rem; height: 2rem; display: inline-flex; align-items: center; justify-content: center; color: var(--foreground); opacity: 0.58; border: 0; border-radius: 999px; background: transparent; cursor: pointer; transition: opacity 0.2s ease, color 0.2s ease, background-color 0.2s ease; }
  .tool-link:hover, .theme-button:hover { opacity: 1; color: var(--accent); background: color-mix(in oklch, var(--accent), transparent 92%); }
  .tool-link svg, .theme-button svg { width: 1.125rem; height: 1.125rem; }
  .theme-button { position: relative; }
  .theme-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); transition: transform 0.2s ease, opacity 0.2s ease; }
  .sun-icon { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .moon-icon { opacity: 0; transform: translate(-50%, -50%) rotate(-90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .sun-icon { opacity: 1; transform: translate(-50%, -50%) rotate(0) scale(1); }
  .preview-page { width: 100%; max-width: var(--preview-width); min-height: calc(100vh - 3.5rem); margin: 0 auto; padding: clamp(5.75rem, 13vh, 8rem) 1rem 3rem; display: flex; flex-direction: column; color: var(--foreground); }
  .search-panel { max-width: 42rem; }
  .search-box { min-height: 4.75rem; padding: 0 1.25rem; display: flex; align-items: center; gap: 0.95rem; border: 1px solid var(--preview-line); border-radius: 1.25rem; background: color-mix(in oklch, var(--foreground), transparent 98%); color: var(--preview-muted); transition: border-color 0.2s ease, background-color 0.2s ease; position: relative; }
  .search-box:focus-within { border-color: color-mix(in oklch, var(--foreground), transparent 68%); background: color-mix(in oklch, var(--foreground), transparent 97%); }
  .search-box svg { width: 1.25rem; height: 1.25rem; flex-shrink: 0; }
  .placeholder-variant { pointer-events: none; position: absolute; left: 3.45rem; right: 1.25rem; top: 50%; transform: translateY(-50%); display: inline-flex; align-items: baseline; gap: 0.65rem; color: color-mix(in oklch, var(--preview-muted), transparent 18%); font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.2; letter-spacing: -0.055em; white-space: nowrap; transition: opacity 0.16s ease; }
  .search-box:has(input:not(:placeholder-shown)) .placeholder-variant { opacity: 0; }
  .search-box input { width: 100%; border: 0; outline: 0; background: transparent; color: var(--foreground); font-size: clamp(1.5rem, 5vw, 2.25rem); line-height: 1.2; letter-spacing: -0.055em; }
  .search-hint, .search-count { margin: 1rem 0 0; color: var(--preview-muted); font-size: 0.8125rem; line-height: 1.8; }
  .result-list { margin: 2rem 0 0; padding: 0; list-style: none; }
  .result-item + .result-item { border-top: 1px solid var(--preview-line); }
  .result-link { display: grid; grid-template-columns: 7.5rem minmax(0, 1fr); gap: 1.5rem; padding: 1.1rem 0; color: inherit; text-decoration: none; }
  .result-link time { color: var(--preview-muted); font-size: 0.8125rem; line-height: 1.7; font-variant-numeric: tabular-nums; }
  .result-content { display: grid; gap: 0.35rem; min-width: 0; }
  .result-title { color: var(--foreground); font-size: 1.05rem; font-weight: 560; line-height: 1.65; letter-spacing: -0.025em; transition: color 0.2s ease, transform 0.2s ease; }
  .result-desc { color: var(--preview-muted); font-size: 0.875rem; line-height: 1.8; display: -webkit-box; overflow: hidden; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .result-link:hover .result-title { color: var(--accent); transform: translateX(0.125rem); }
  .result-item[hidden] { display: none; }
  .site-footer { margin-top: auto; padding-top: 1.25rem; border-top: 1px solid var(--preview-line); display: flex; align-items: center; justify-content: space-between; gap: 1rem; color: var(--preview-muted); font-size: 0.8125rem; line-height: 1.7; }
  .footer-legal, .footer-links { display: inline-flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
  .site-footer a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .site-footer a:hover { color: var(--accent); }
  .separator { color: color-mix(in oklch, var(--preview-muted), transparent 42%); }
  @media (max-width: 640px) { .preview-page { min-height: calc(100vh - 3rem); padding-top: 4.75rem; } .search-box { min-height: 4rem; border-radius: 1rem; padding: 0 1rem; } .placeholder-variant { left: 3.05rem; right: 1rem; font-size: 1.35rem; gap: 0.45rem; } .search-box input { font-size: 1.35rem; } .result-link { grid-template-columns: 1fr; gap: 0.2rem; padding: 1rem 0; } .result-link time { font-size: 0.75rem; } .site-footer { align-items: flex-start; flex-direction: column-reverse; gap: 0.5rem; } }
</style>

<script is:inline>
  const input = document.querySelector("#preview-search-input");
  const items = Array.from(document.querySelectorAll(".result-item"));
  const count = document.querySelector("#preview-search-count");
  const countLine = count?.closest(".search-count");
  function updateResults(value) {
    let visible = 0;
    items.forEach(item => {
      const text = `${item.dataset.title ?? ""} ${item.dataset.desc ?? ""} ${item.dataset.tags ?? ""}`;
      const matched = value.length > 0 && text.includes(value);
      item.toggleAttribute("hidden", !matched);
      if (matched) visible += 1;
    });
    countLine?.toggleAttribute("hidden", value.length === 0);
    if (count) count.textContent = `找到 ${visible} 个结果`;
  }
  const params = new URLSearchParams(window.location.search);
  const presetQuery = params.get("q")?.trim() ?? "";
  if (input instanceof HTMLInputElement && presetQuery) {
    input.value = presetQuery;
    updateResults(presetQuery.toLowerCase());
  }
  input?.addEventListener("input", event => {
    const value = event.target instanceof HTMLInputElement ? event.target.value.trim().toLowerCase() : "";
    updateResults(value);
  });
</script>
