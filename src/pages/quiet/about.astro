---
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import { SITE } from "@/config";

---

<QuietLayout footerMode="balanced" title={`关于预览 | ${SITE.title}`} description="关于 J2 和摸鱼时刻的轻量说明预览。">

  <main id="main-content" class="about-preview">
    <header class="about-hero">
      <h1>关于这里</h1>
      <p>这里是 J2 的摸鱼小博客，随便写写，认真存档</p>
    </header>

    <article class="about-body" aria-label="关于内容">
      <p>
        写点东西，不求高产，只求不断。主题大多随缘：效率、工具、AI、产品，以及一些生活碎片。
      </p>
      <p>
        这个站点的目标很简单：把脑子里的噪音，变成以后还能复用的文字。
      </p>

      <h2>关于小Biu</h2>
      <p>
        小Biu 是这儿的 AI 搭子，负责把碎片想法捋顺、润色成文，顺手处理标题、摘要、标签和排版。
      </p>
      <p>
        主打一个不催更，但真能把“想写”往“写完”推一把。
      </p>

      <h2>致谢</h2>
      <p>
        本站基于开源主题 <a href="https://github.com/satnaing/astro-paper" target="_blank" rel="noopener">AstroPaper</a> 调整而来。感谢原作者与贡献者。
      </p>
    </article>

  </main>
</QuietLayout>

<style>
  :global(html) {
    --preview-width: 48rem;
    --article-width: 42rem;
    --preview-line: oklch(88% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 48%);
  }

  :global(html[data-theme="dark"]) {
    --preview-line: oklch(31% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 38%);
  }

  .preview-skip {
    position: absolute;
    inset-inline-start: 1rem;
    top: -100%;
    z-index: 50;
    padding: 0.5rem 0.75rem;
    background: var(--background);
    color: var(--accent);
    transition: top 0.2s ease;
  }

  .preview-skip:focus {
    top: 1rem;
  }

  .preview-header {
    width: 100%;
    padding-top: 1.5rem;
  }

  .preview-header-inner {
    width: 100%;
    max-width: var(--preview-width);
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .preview-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--foreground);
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 650;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .brand-logo {
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
  }

  .preview-tools {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .tool-link,
  .theme-button {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--foreground);
    opacity: 0.58;
    border: 0;
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    transition: opacity 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .tool-link:hover,
  .theme-button:hover {
    opacity: 1;
    color: var(--accent);
    background: color-mix(in oklch, var(--accent), transparent 92%);
  }

  .tool-link svg,
  .theme-button svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .theme-button {
    position: relative;
  }

  .theme-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .sun-icon {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(90deg) scale(0.65);
  }

  :global(html[data-theme="dark"]) .moon-icon {
    opacity: 0;
    transform: translate(-50%, -50%) rotate(-90deg) scale(0.65);
  }

  :global(html[data-theme="dark"]) .sun-icon {
    opacity: 1;
    transform: translate(-50%, -50%) rotate(0) scale(1);
  }

  .about-preview {
    width: 100%;
    max-width: var(--preview-width);
    margin: 0 auto;
    padding: 6.25rem 1rem 3rem;
    color: var(--foreground);
  }

  .about-hero {
    max-width: var(--article-width);
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--preview-line);
  }

  .about-hero h1 {
    margin: 0;
    max-width: 14em;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.08;
    letter-spacing: -0.055em;
    font-weight: 680;
  }

  .about-hero p {
    margin: 1.25rem 0 0;
    max-width: 35rem;
    color: var(--preview-muted);
    font-size: 1rem;
    line-height: 1.8;
  }

  .about-body {
    max-width: var(--article-width);
    padding: 2.75rem 0 3.75rem;
    border-bottom: 1px solid var(--preview-line);
    color: color-mix(in oklch, var(--foreground), var(--preview-muted) 18%);
    font-size: 1rem;
    line-height: 1.9;
  }

  .about-body p {
    margin: 0;
  }

  .about-body p + p {
    margin-top: 1rem;
  }

  .about-body h2 {
    margin: 2.5rem 0 0.85rem;
    color: var(--foreground);
    font-size: 1.25rem;
    line-height: 1.35;
    letter-spacing: -0.035em;
    font-weight: 650;
  }

  .about-body a {
    color: var(--foreground);
    text-decoration: underline;
    text-decoration-color: color-mix(in oklch, var(--foreground), transparent 72%);
    text-underline-offset: 0.25em;
  }

  .about-body a:hover {
    color: var(--accent);
    text-decoration-color: var(--accent);
  }

  @media (max-width: 640px) {
    .preview-header-inner {
      padding: 0 1.25rem;
    }

    .about-preview {
      padding: 4.75rem 1.25rem 2.5rem;
    }

    .about-hero {
      padding-bottom: 2.5rem;
    }


  }
</style>

<script>
  function applyStoredTheme() {
    const root = document.documentElement;
    const storedTheme = localStorage.getItem("theme");
    if (storedTheme === "light" || storedTheme === "dark") {
      root.dataset.theme = storedTheme;
    }
  }

  applyStoredTheme();
  document.addEventListener("astro:after-swap", applyStoredTheme);
</script>
