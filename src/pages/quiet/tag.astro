---
import { getCollection } from "astro:content";
import QuietLayout from "@/themes/quiet/layouts/QuietLayout.astro";
import getPostsByTag from "@/utils/getPostsByTag";
import getUniqueTags from "@/utils/getUniqueTags";
import { getQuietPath } from "@/utils/getQuietPath";
import { SITE } from "@/config";
import dayjs from "dayjs";
import timezone from "dayjs/plugin/timezone";
import utc from "dayjs/plugin/utc";

dayjs.extend(utc);
dayjs.extend(timezone);

const posts = await getCollection("blog", ({ data }) => !data.draft);
const tagSummaries = getUniqueTags(posts)
  .map(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    return { tag, tagName, count: tagPosts.length, posts: tagPosts };
  })
  .sort((tagA, tagB) => tagB.count - tagA.count || tagA.tagName.localeCompare(tagB.tagName));

const previewTag = tagSummaries[0];
const latestDate = previewTag?.posts.length
  ? dayjs(previewTag.posts[0].data.pubDatetime).tz(SITE.timezone).format("YYYY.MM.DD")
  : "";

const postItems = previewTag?.posts.map(post => ({
  title: post.data.title,
  description: post.data.description ?? "",
  date: dayjs(post.data.pubDatetime).tz(SITE.timezone).format("YYYY.MM.DD"),
  href: getQuietPath(post.id, post.filePath),
})) ?? [];
---

<QuietLayout title={`标签详情预览 | ${SITE.title}`} description="单个标签文章列表的新版预览。">

  <main id="main-content" class="preview-page">
    <header class="page-hero">
      <div class="hero-line">
        <p class="page-kicker">Tag</p>
        <a href="/quiet/tags" class="all-tags-link">全部主题 →</a>
      </div>
      <h1>{previewTag?.tagName ?? "标签"}</h1>
      <p>
        {previewTag?.count ?? 0} 篇文章
        {latestDate && <span> · 最近更新 {latestDate}</span>}
      </p>
    </header>

    <section class="post-index" aria-label="标签文章列表">
      <ul class="post-list">
        {postItems.map(item => (
          <li class="post-item">
            <a href={item.href} class="post-link">
              <time>{item.date}</time>
              <span class="post-content">
                <span class="post-title">{item.title}</span>
                {item.description && <span class="post-desc">{item.description}</span>}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>

  </main>
</QuietLayout>

<style>
  :global(html) { --preview-width: 48rem; --preview-line: oklch(88% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 48%); }
  :global(html[data-theme="dark"]) { --preview-line: oklch(31% 0.006 250); --preview-muted: color-mix(in oklch, var(--foreground), transparent 38%); }
  .preview-skip { position: absolute; inset-inline-start: 1rem; top: -100%; z-index: 50; padding: 0.5rem 0.75rem; background: var(--background); color: var(--accent); transition: top 0.2s ease; }
  .preview-skip:focus { top: 1rem; }
  .preview-header { width: 100%; padding-top: 1.5rem; }
  .preview-header-inner { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 0 1rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .preview-brand { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--foreground); text-decoration: none; font-size: 1.25rem; font-weight: 650; line-height: 1; letter-spacing: -0.03em; }
  .brand-logo { width: 2rem; height: 2rem; flex-shrink: 0; }
  .preview-tools { display: inline-flex; align-items: center; gap: 0.375rem; }
  .tool-link, .theme-button { width: 2rem; height: 2rem; display: inline-flex; align-items: center; justify-content: center; color: var(--foreground); opacity: 0.58; border: 0; border-radius: 999px; background: transparent; cursor: pointer; transition: opacity 0.2s ease, color 0.2s ease, background-color 0.2s ease; }
  .tool-link:hover, .theme-button:hover { opacity: 1; color: var(--accent); background: color-mix(in oklch, var(--accent), transparent 92%); }
  .tool-link svg, .theme-button svg { width: 1.125rem; height: 1.125rem; }
  .theme-button { position: relative; }
  .theme-icon { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); transition: transform 0.2s ease, opacity 0.2s ease; }
  .sun-icon { opacity: 0; transform: translate(-50%, -50%) rotate(90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .moon-icon { opacity: 0; transform: translate(-50%, -50%) rotate(-90deg) scale(0.65); }
  :global(html[data-theme="dark"]) .sun-icon { opacity: 1; transform: translate(-50%, -50%) rotate(0) scale(1); }
  .preview-page { width: 100%; max-width: var(--preview-width); margin: 0 auto; padding: 5rem 1rem 3rem; color: var(--foreground); }
  .page-hero { padding-bottom: 2.5rem; border-bottom: 1px solid var(--preview-line); }
  .hero-line { margin: 0 0 0.75rem; display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
  .page-kicker { margin: 0 0 0.75rem; color: var(--preview-muted); font-size: 0.75rem; line-height: 1; letter-spacing: 0.12em; text-transform: uppercase; }
  .hero-line .page-kicker { margin: 0; }
  .all-tags-link { position: fixed; top: 5rem; right: max(1rem, calc((100vw - var(--preview-width)) / 2 + 1rem)); z-index: 20; color: var(--preview-muted); font-size: 0.875rem; line-height: 1.7; text-decoration: none; transition: color 0.2s ease, transform 0.2s ease, opacity 0.2s ease; }
  .all-tags-link:hover { color: var(--accent); transform: translateX(0.125rem); }
  .page-hero h1 { margin: 0; color: var(--foreground); font-size: clamp(2rem, 7vw, 4.5rem); font-weight: 680; line-height: 0.98; letter-spacing: -0.065em; }
  .page-hero p { margin: 1.25rem 0 0; color: var(--preview-muted); font-size: 0.9375rem; line-height: 1.8; }
  .post-index { padding-top: 2rem; }
  .post-list { margin: 0; padding: 0; list-style: none; }
  .post-item + .post-item { border-top: 1px solid var(--preview-line); }
  .post-link { display: grid; grid-template-columns: 7.5rem minmax(0, 1fr); gap: 1.5rem; padding: 1.1rem 0; color: inherit; text-decoration: none; }
  .post-link time { color: var(--preview-muted); font-size: 0.8125rem; line-height: 1.7; font-variant-numeric: tabular-nums; }
  .post-content { display: grid; gap: 0.35rem; min-width: 0; }
  .post-title { color: var(--foreground); font-size: 1.05rem; font-weight: 560; line-height: 1.65; letter-spacing: -0.025em; transition: color 0.2s ease, transform 0.2s ease; }
  .post-desc { color: var(--preview-muted); font-size: 0.875rem; line-height: 1.8; display: -webkit-box; overflow: hidden; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
  .post-link:hover .post-title { color: var(--accent); transform: translateX(0.125rem); }
  .separator { color: color-mix(in oklch, var(--preview-muted), transparent 42%); }
  @media (max-width: 640px) { .preview-page { padding-top: 3.75rem; } .hero-line { align-items: center; } .all-tags-link { position: static; font-size: 0.8125rem; } .post-link { grid-template-columns: 1fr; gap: 0.2rem; padding: 1rem 0; } .post-link time { font-size: 0.75rem; } }
</style>
